[
  {
    "namespace": "zenInternals",
    "description": "Access Zen Browser internal APIs for workspace/folder management",
    "functions": [
      {
        "name": "createFolder",
        "type": "function",
        "async": true,
        "description": "Create a Zen folder in the sidebar",
        "parameters": [
          {
            "name": "options",
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Folder name" },
              "collapsed": { "type": "boolean", "optional": true },
              "userIcon": { "type": "string", "optional": true },
              "workspaceName": { "type": "string", "optional": true, "description": "Target workspace name" },
              "tabIds": { "type": "array", "optional": true, "items": { "type": "integer" }, "description": "WebExtension tab IDs to include in the folder (preferred over tabUrls)" },
              "tabUrls": { "type": "array", "optional": true, "items": { "type": "string" }, "description": "URLs of tabs to include in the folder (fallback when tabIds unavailable)" }
            }
          }
        ]
      },
      {
        "name": "getFolders",
        "type": "function",
        "async": true,
        "description": "Get all Zen folders",
        "parameters": []
      },
      {
        "name": "getWorkspaces",
        "type": "function",
        "async": true,
        "description": "Get all Zen workspaces with their UUIDs and names",
        "parameters": []
      },
      {
        "name": "organizeTab",
        "type": "function",
        "async": true,
        "description": "Set essential/workspace on a tab via Zen internal APIs",
        "parameters": [
          {
            "name": "tabId",
            "type": "integer",
            "description": "WebExtension tab ID"
          },
          {
            "name": "options",
            "type": "object",
            "properties": {
              "essential": { "type": "boolean", "optional": true },
              "removeEssential": { "type": "boolean", "optional": true },
              "workspaceUuid": { "type": "string", "optional": true }
            }
          }
        ]
      },
      {
        "name": "getTabData",
        "type": "function",
        "async": true,
        "description": "Read all tabs, workspaces, and folders from chrome context",
        "parameters": []
      },
      {
        "name": "createWorkspace",
        "type": "function",
        "async": true,
        "description": "Create a Zen workspace via gZenWorkspaces.saveWorkspace()",
        "parameters": [
          {
            "name": "options",
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Workspace name" },
              "icon": { "type": "string", "optional": true }
            }
          }
        ]
      },
      {
        "name": "removeFolder",
        "type": "function",
        "async": true,
        "description": "Remove a Zen folder by name via folder.delete()",
        "parameters": [
          {
            "name": "options",
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Folder name to remove" }
            }
          }
        ]
      },
      {
        "name": "updateFolder",
        "type": "function",
        "async": true,
        "description": "Update folder properties (name, collapsed, icon)",
        "parameters": [
          {
            "name": "options",
            "type": "object",
            "properties": {
              "currentName": { "type": "string", "description": "Current folder name to find" },
              "name": { "type": "string", "optional": true, "description": "New folder name" },
              "collapsed": { "type": "boolean", "optional": true },
              "icon": { "type": "string", "optional": true }
            }
          }
        ]
      }
    ]
  }
]
